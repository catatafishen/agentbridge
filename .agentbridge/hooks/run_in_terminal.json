{
  "permission": [
    {
      "script": "scripts/run-in-terminal-abort.js",
      "rejectOnFailure": true,
      "timeout": 10
    }
  ],
  "pre": [
    {
      "script": "scripts/enforce-gh-bot-identity.js",
      "failSilently": false,
      "timeout": 15,
      "capabilities": [
        "filesystem",
        "subprocess"
      ]
    }
  ],
  "success": [
    {
      "script": "scripts/command-reprimand.js",
      "timeout": 10,
      "failSilently": true
    }
  ]
}
